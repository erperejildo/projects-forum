{
  "homepage": "https://drodriguez-support.com",
  "name": "projects-forum",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prepare:env": "node scripts/generate-environment.mjs",
    "start": "npm run prepare:env && ng serve",
    "build": "npm run prepare:env && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "npm run prepare:env && ng test",
    "test:ci": "npm run prepare:env && ng test --watch=false",
    "lint": "ng lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "dotenv": "^17.3.1",
    "firebase": "^12.10.0",
    "heroicons": "^2.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.3.0",
    "eslint": "^10.0.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8",
    "gh-pages": "^6.3.0"
  }
}
